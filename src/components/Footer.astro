---
const today = new Date();
import { SITE_COMPANY } from '../consts';
---

<footer>
	<div class="footer-content">
		<span>&copy; {today.getFullYear()} {SITE_COMPANY}</span>
	</div>
</footer>
<style>
	footer {
		padding: 3em 1em;
		border-top: none;
		color: var(--text-muted);
		text-align: center;
		font-size: 0.85rem;
	}
	.footer-content {
		display: flex;
		align-items: center;
		justify-content: center;
		gap: 0.5em;
		flex-wrap: wrap;
	}
	.sep { color: var(--border); }
	footer a {
		color: var(--text-muted);
		text-decoration: none;
		transition: color 0.15s ease;
	}
	footer a:hover { color: var(--accent); }
</style>
